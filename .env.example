# ── Backend Configuration (Flask) ─────────────────────────────────────────────
# Set to 'true' in production to enable secure cookies and strict security
PRODUCTION=false

# Secret key for session encryption. CHANGE THIS IN PRODUCTION.
SECRET_KEY=dev-secret-key-change-in-production

# Backend server port
BACKEND_PORT=5001

# Database URL. Defaults to a local SQLite file in the 'instance' folder if not set.
# Example for PostgreSQL: postgresql://user:password@localhost:5432/rewear
SQLALCHEMY_DATABASE_URI=

# Allowed CORS origins (comma-separated). Defaults to http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Storage Provider (Stateless attached resource)
# Options: LOCAL, S3 (S3 requires additional AWS configuration)
STORAGE_PROVIDER=LOCAL

# Binary Asset Storage (If using LOCAL provider)
# Path to store uploaded images. Defaults to './uploads'
UPLOAD_FOLDER=

# ML Model Hub (Attached Resource)
# Repository and filename for the YOLO model on Hugging Face
ML_MODEL_REPO=Bingsu/adetailer
ML_MODEL_FILENAME=deepfashion2_yolov8s-seg.pt
ML_MODEL_FALLBACK=yolov8n.pt

# Flask configuration (for local development)
FLASK_APP=rewear_app/app.py
FLASK_DEBUG=1


# ── Frontend Configuration (Vite) ─────────────────────────────────────────────
# Port the Vite dev server runs on
VITE_PORT=3000

# Base URL for the Backend API (Target for the Vite proxy)
VITE_PROXY_TARGET=http://localhost:5001
